{
  "name": "budgetos",
  "private": true,
  "version": "1.0.0",
  "description": "AI-powered personal finance system",
  "type": "module",
  "workspaces": [
    "shared",
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:engine": "turbo run build --filter=@budgetos/engine",
    "build:client": "turbo run build --filter=@budgetos/client",
    "dev": "turbo run dev --parallel",
    "dev:engine": "turbo run dev --filter=@budgetos/engine",
    "dev:client": "turbo run dev --filter=@budgetos/client",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:engine": "turbo run test --filter=@budgetos/engine",
    "test:coverage": "turbo run test:coverage --filter=@budgetos/engine",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@types/node": "22.20.0",
    "eslint": "^9.0.0",
    "jsdom": "29.1.1",
    "prettier": "^3.4.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@10.9.0",
  "dependencies": {
    "jspdf": "4.2.1",
    "jspdf-autotable": "5.0.8",
    "xlsx": "0.18.5"
  }
}

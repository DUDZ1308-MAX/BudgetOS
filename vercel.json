{
  "buildCommand": "npm run build",
  "outputDirectory": "apps/web/dist",
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "budget-os-web.vercel.app"
        }
      ],
      "destination": "https://budgetos-rust.vercel.app/",
      "permanent": true
    },
    {
      "source": "/:path+",
      "has": [
        {
          "type": "host",
          "value": "budget-os-web.vercel.app"
        }
      ],
      "destination": "https://budgetos-rust.vercel.app/:path+",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}


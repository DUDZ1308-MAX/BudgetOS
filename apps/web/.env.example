# ── App ──────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173

# ── Supabase (public — safe to expose) ───────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Stripe (public — safe to expose) ─────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# Stripe Price IDs
VITE_STRIPE_PRICE_PRO_MONTH=price_pro_month
VITE_STRIPE_PRICE_PRO_YEAR=price_pro_year
VITE_STRIPE_PRICE_PREMIUM_MONTH=price_premium_month
VITE_STRIPE_PRICE_PREMIUM_YEAR=price_premium_year

# Stripe API endpoints (defaults to proxy via your own backend)
VITE_STRIPE_CHECKOUT_URL=/api/stripe/create-checkout
VITE_STRIPE_PORTAL_URL=/api/stripe/customer-portal
VITE_STRIPE_WEBHOOK_ENDPOINT=/api/stripe/webhook
